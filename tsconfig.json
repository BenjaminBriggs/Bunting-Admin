{
	"extends": "@guardian/tsconfig/tsconfig.json",
	"compilerOptions": {
		// TODO(guardian-alignment): ratchet these three flags from @guardian/tsconfig
		// back on and fix the ~200 existing violations (165 unused locals,
		// ~35 unchecked-index accesses, 1 implicit return). Relaxed for now to keep
		// parity with the project's prior `strict`-only baseline.
		"noUnusedLocals": false,
		"noUncheckedIndexedAccess": false,
		"noImplicitReturns": false,
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"noEmit": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@/components/*": ["./src/components/*"],
			"@/lib/*": ["./src/lib/*"],
			"@/types/*": ["./src/types/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
