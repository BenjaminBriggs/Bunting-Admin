# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bunting_admin"

# Storage (single global S3-compatible bucket; apps are namespaced by identifier)
S3_BUCKET="bunting-configs"
S3_REGION="us-east-1"
# Custom endpoint for S3-compatible stores (MinIO, R2, B2). Omit for AWS S3.
# S3_ENDPOINT="https://s3.amazonaws.com"
# Access keys are OPTIONAL: omit them in production to use the instance's IAM
# role (e.g. the Fargate task role). Set them locally for MinIO.
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"

# Public read URL base. The SDK fetch URL for each app is CDN_BASE_URL/<identifier>/.
# If unset, it is derived from S3_ENDPOINT+bucket (MinIO) or the AWS virtual-host URL.
CDN_BASE_URL="https://cdn.example.com"

# Signing-key encryption at rest
# Signing private keys are generated by the app and stored ENCRYPTED in the
# database. Choose one protection scheme:
#   - AWS KMS (recommended in prod): the app's IAM role must allow kms:Encrypt/Decrypt.
# SIGNING_KEY_KMS_KEY_ID="arn:aws:kms:region:account:key/key-id"
#   - Local AES-256-GCM (self-host / dev): a high-entropy secret (e.g. `openssl rand -hex 32`).
# SIGNING_KEY_SECRET="change-me-32-bytes-min"
# If neither is set, the app refuses to create/sign keys (no plaintext at rest).

# App Configuration
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# ========================================
# AUTHENTICATION CONFIGURATION
# ========================================
# AUTH_MODE selects how users are authenticated:
#   oidc  (default) — the app is an OpenID Connect relying party (bring your own IdP)
#   proxy           — a trusted reverse-proxy / IAP in front authenticates users
AUTH_MODE="oidc"

# ----------------------------------------
# Generic OIDC (recommended "bring your own auth")
# ----------------------------------------
# Works with Okta, Auth0, Keycloak, Google Workspace, Azure, etc.
# In local dev, docker-compose points these at the bundled `dex` container.
# OIDC_ISSUER="https://your-idp.example.com"
# OIDC_CLIENT_ID="your-client-id"
# OIDC_CLIENT_SECRET="your-client-secret"
# OIDC_PROVIDER_NAME="SSO"          # button label (optional)
# OIDC_SCOPES="openid email profile" # optional scope override
# Redirect URL to register with your IdP: <NEXTAUTH_URL>/api/auth/callback/oidc

# ----------------------------------------
# Proxy / forward-auth mode (AUTH_MODE=proxy)
# ----------------------------------------
# The app trusts an upstream proxy (oauth2-proxy, Pomerium, Cloudflare Access,
# Google IAP, Guardian SSO). Plain-header trust REQUIRES the app to be network-
# isolated to the proxy; prefer signed-JWT verification when available.
# AUTH_PROXY_EMAIL_HEADER="x-forwarded-email"
# Signed-assertion verification (preferred):
# AUTH_PROXY_JWKS_URL="https://proxy.example.com/cdn-cgi/access/certs"
# AUTH_PROXY_JWT_HEADER="cf-access-jwt-assertion"
# AUTH_PROXY_JWT_AUDIENCE="your-audience"
# AUTH_PROXY_JWT_EMAIL_CLAIM="email"

# ----------------------------------------
# OAuth Providers (optional convenience providers)
# ----------------------------------------
# Choose any combination of OAuth providers below

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# Microsoft OAuth (Azure AD)
# Get credentials from: https://portal.azure.com/
# MICROSOFT_CLIENT_ID="your-microsoft-client-id"
# MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
# MICROSOFT_TENANT_ID="your-tenant-id"

# ----------------------------------------
# Email Authentication (optional)
# ----------------------------------------
# Magic link authentication via Resend
# Get API key from: https://resend.com/
# RESEND_API_KEY="re_your_api_key"
# EMAIL_FROM="noreply@your-domain.com"

# ----------------------------------------
# Notes
# ----------------------------------------
# - Local dev uses real OIDC against the bundled `dex` container
#   (login: admin@bunting.dev / password). There is no credentials bypass.
# - In production (oidc mode): at least one provider (generic OIDC or a named
#   one) must be configured, or the app refuses to boot.
# - Users only see configured authentication methods.
# - OAuth redirect URLs should be: <NEXTAUTH_URL>/api/auth/callback/[provider]

# ----------------------------------------
# Observability (optional)
# ----------------------------------------
# Structured JSON logs are written to stdout. Set the minimum level:
# trace | debug | info | warn | error | fatal. Defaults to `info` in
# production and `debug` otherwise.
# LOG_LEVEL="info"

# Optional: Development
NODE_ENV="development"